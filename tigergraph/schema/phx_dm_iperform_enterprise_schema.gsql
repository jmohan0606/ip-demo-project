USE GLOBAL

DROP GRAPH iperform_insights_coaching_demo

CREATE VERTEX phx_dm_firm(PRIMARY_ID firm_id STRING, name STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_division(PRIMARY_ID division_id STRING, name STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_region(PRIMARY_ID region_id STRING, name STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_market(PRIMARY_ID market_id STRING, name STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_advisor(PRIMARY_ID advisor_id STRING, name STRING, mdw_id STRING, ddw_id STRING, agp_enrolled BOOL) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_household(PRIMARY_ID household_id STRING, name STRING, segment STRING, risk_score DOUBLE) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_account(PRIMARY_ID account_id STRING, account_type STRING, aum DOUBLE) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_product(PRIMARY_ID product_id STRING, category STRING, subcategory STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_revenue_transaction(PRIMARY_ID transaction_id STRING, amount DOUBLE, revenue_type STRING, transaction_date DATETIME) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_opportunity(PRIMARY_ID opportunity_id STRING, title STRING, score DOUBLE, impact DOUBLE, priority STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_recommendation(PRIMARY_ID recommendation_id STRING, title STRING, confidence DOUBLE, impact DOUBLE, status STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_feedback(PRIMARY_ID feedback_id STRING, action STRING, notes STRING, created_at DATETIME) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_memory(PRIMARY_ID memory_id STRING, memory_type STRING, title STRING, content STRING, importance DOUBLE) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_context_packet(PRIMARY_ID context_id STRING, token_estimate INT, compressed_context STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_agent_execution(PRIMARY_ID execution_id STRING, workflow STRING, status STRING, started_at DATETIME) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_tool_call(PRIMARY_ID tool_call_id STRING, tool_name STRING, status STRING, duration_ms INT) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_document(PRIMARY_ID document_id STRING, document_name STRING, document_type STRING, chunk_count INT) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_document_chunk(PRIMARY_ID chunk_id STRING, document_id STRING, chunk_index INT, content STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_feature_vector(PRIMARY_ID feature_vector_id STRING, entity_type STRING, entity_id STRING, feature_count INT) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_prediction(PRIMARY_ID prediction_id STRING, target STRING, baseline DOUBLE, predicted DOUBLE, confidence DOUBLE) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_scenario(PRIMARY_ID scenario_id STRING, scope_id STRING, status STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_compliance_rule(PRIMARY_ID rule_id STRING, rule_name STRING, severity STRING) WITH primary_id_as_attribute="true"
CREATE VERTEX phx_dm_compliance_check(PRIMARY_ID check_id STRING, status STRING, checked_at DATETIME) WITH primary_id_as_attribute="true"

CREATE DIRECTED EDGE phx_dm_has_division(FROM phx_dm_firm, TO phx_dm_division)
CREATE DIRECTED EDGE phx_dm_has_region(FROM phx_dm_division, TO phx_dm_region)
CREATE DIRECTED EDGE phx_dm_has_market(FROM phx_dm_region, TO phx_dm_market)
CREATE DIRECTED EDGE phx_dm_has_advisor(FROM phx_dm_market, TO phx_dm_advisor)
CREATE DIRECTED EDGE phx_dm_serves_household(FROM phx_dm_advisor, TO phx_dm_household)
CREATE DIRECTED EDGE phx_dm_owns_account(FROM phx_dm_household, TO phx_dm_account)
CREATE DIRECTED EDGE phx_dm_holds_product(FROM phx_dm_account, TO phx_dm_product)
CREATE DIRECTED EDGE phx_dm_generated_revenue(FROM phx_dm_account, TO phx_dm_revenue_transaction)
CREATE DIRECTED EDGE phx_dm_has_opportunity(FROM phx_dm_household, TO phx_dm_opportunity)
CREATE DIRECTED EDGE phx_dm_generates_recommendation(FROM phx_dm_opportunity, TO phx_dm_recommendation)
CREATE DIRECTED EDGE phx_dm_has_feedback(FROM phx_dm_recommendation, TO phx_dm_feedback)
CREATE DIRECTED EDGE phx_dm_has_memory(FROM phx_dm_advisor, TO phx_dm_memory)
CREATE DIRECTED EDGE phx_dm_has_context_packet(FROM phx_dm_advisor, TO phx_dm_context_packet)
CREATE DIRECTED EDGE phx_dm_executed_tool(FROM phx_dm_agent_execution, TO phx_dm_tool_call)
CREATE DIRECTED EDGE phx_dm_has_chunk(FROM phx_dm_document, TO phx_dm_document_chunk)
CREATE DIRECTED EDGE phx_dm_uses_document(FROM phx_dm_recommendation, TO phx_dm_document)
CREATE DIRECTED EDGE phx_dm_has_feature_vector(FROM phx_dm_advisor, TO phx_dm_feature_vector)
CREATE DIRECTED EDGE phx_dm_generated_prediction(FROM phx_dm_feature_vector, TO phx_dm_prediction)
CREATE DIRECTED EDGE phx_dm_has_scenario(FROM phx_dm_advisor, TO phx_dm_scenario)
CREATE DIRECTED EDGE phx_dm_checked_by_rule(FROM phx_dm_compliance_check, TO phx_dm_compliance_rule)

CREATE GRAPH iperform_insights_coaching_demo(
  phx_dm_firm, phx_dm_division, phx_dm_region, phx_dm_market, phx_dm_advisor,
  phx_dm_household, phx_dm_account, phx_dm_product, phx_dm_revenue_transaction,
  phx_dm_opportunity, phx_dm_recommendation, phx_dm_feedback, phx_dm_memory,
  phx_dm_context_packet, phx_dm_agent_execution, phx_dm_tool_call,
  phx_dm_document, phx_dm_document_chunk, phx_dm_feature_vector,
  phx_dm_prediction, phx_dm_scenario, phx_dm_compliance_rule, phx_dm_compliance_check,
  phx_dm_has_division, phx_dm_has_region, phx_dm_has_market, phx_dm_has_advisor,
  phx_dm_serves_household, phx_dm_owns_account, phx_dm_holds_product,
  phx_dm_generated_revenue, phx_dm_has_opportunity, phx_dm_generates_recommendation,
  phx_dm_has_feedback, phx_dm_has_memory, phx_dm_has_context_packet,
  phx_dm_executed_tool, phx_dm_has_chunk, phx_dm_uses_document,
  phx_dm_has_feature_vector, phx_dm_generated_prediction, phx_dm_has_scenario,
  phx_dm_checked_by_rule
)
