# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
.env
.env.*
!.env.example

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/coverage/
frontend/.env.local
frontend/.env.*.local
!frontend/.env.local.example

# Playwright
frontend/playwright-report/
frontend/test-results/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Logs/temp
*.log
*.tmp
tmp/
temp/

# Local runtime outputs
data/uploads/*
!data/uploads/.gitkeep
# Runtime document uploads (ingested via /knowledge/upload; corpus lives in
# data/documents/sample_knowledge, uploads are runtime-only)
data/documents/uploads/
docs/ui_runtime/screenshots/*
!docs/ui_runtime/screenshots/.gitkeep
*.tsbuildinfo

# ChromaDB runtime state (regenerated at runtime; must not be committed — a stale
# fallback sqlite here previously corrupted the real chromadb client)
data/chroma/chroma.sqlite3
data/chroma/*/

# Runtime SQLite DBs (feature store + pipeline artifacts) — regenerated at runtime;
# verification runs mutate them, so they must not be tracked (git-hygiene flag from Session 2)
data/feature_store/*.db
data/sqlite/*.db

# QA screenshots (regenerated each run; not tracked)
docs/qa_screenshots/

# Section 11.1: trained model binary artifacts — regenerated by scripts/train/*; the
# committed source of truth is models/registry.json (metrics + metadata only).
models/artifacts/*
!models/artifacts/.gitkeep

# Stray runtime DBs written when a tool runs from the frontend/ CWD (belongs at repo-root data/)
frontend/data/
**/data/feature_store/*.db
