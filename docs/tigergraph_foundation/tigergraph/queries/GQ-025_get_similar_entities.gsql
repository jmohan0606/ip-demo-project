/*
 * GQ-025 — get_similar_entities
 * Purpose: Return nearest-neighbor similarity records and target entities.
 * Outputs: similarity matches and typed target sets
 * Compatibility target: TigerGraph 4.2.x, classic GSQL SYNTAX V1.
 */
USE GRAPH iperform_insights_coaching_demo

CREATE QUERY get_similar_entities(STRING entity_type, STRING entity_id, INT result_limit, DOUBLE min_score) FOR GRAPH iperform_insights_coaching_demo SYNTAX V1 {
    all_matches = {phx_dm_similarity_match.*};
    matches = SELECT s FROM all_matches:s
        WHERE s.entity_type == entity_type
          AND s.source_entity_id == entity_id
          AND s.similarity_score >= min_score
        ORDER BY s.similarity_score DESC
        LIMIT result_limit;
    advisors = SELECT a FROM matches:s
        -(phx_dm_similarity_match_targets_advisor:e_a)- phx_dm_advisor:a;
    households = SELECT h FROM matches:s
        -(phx_dm_similarity_match_targets_household:e_h)- phx_dm_household:h;
    accounts = SELECT ac FROM matches:s
        -(phx_dm_similarity_match_targets_account:e_ac)- phx_dm_account:ac;
    products = SELECT p FROM matches:s
        -(phx_dm_similarity_match_targets_product:e_p)- phx_dm_product:p;

    PRINT entity_type, entity_id, matches,
        advisors AS similar_advisors,
        households AS similar_households,
        accounts AS similar_accounts,
        products AS similar_products;
}

INSTALL QUERY get_similar_entities
