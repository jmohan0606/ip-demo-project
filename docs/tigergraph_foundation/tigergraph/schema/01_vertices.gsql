CREATE VERTEX phx_dm_conversation_turn (PRIMARY_ID turn_id STRING, conversation_id STRING, turn_no INT, speaker STRING, content STRING, created_at DATETIME, intent STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_reasoning_trace (PRIMARY_ID reasoning_id STRING, artifact_type STRING, artifact_id STRING, reasoning_steps_json STRING, evidence_json STRING, model_name STRING, prompt_version STRING, confidence DOUBLE, created_at DATETIME) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_document (PRIMARY_ID document_id STRING, title STRING, document_type STRING, source STRING, version STRING, status STRING, published_date DATETIME) WITH primary_id_as_attribute="true";
