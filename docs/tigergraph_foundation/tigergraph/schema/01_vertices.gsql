CREATE VERTEX phx_dm_goal (PRIMARY_ID goal_id STRING, goal_name STRING, goal_type STRING, target_value DOUBLE, unit STRING, start_date DATETIME, end_date DATETIME, status STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_kpi (PRIMARY_ID kpi_id STRING, kpi_name STRING, kpi_code STRING, unit STRING, direction STRING, status STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_agp_kpi_measurement (PRIMARY_ID measurement_id STRING, target_value DOUBLE, actual_value DOUBLE, attainment_pct DOUBLE, status STRING, measured_at DATETIME) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_coaching_session (PRIMARY_ID session_id STRING, session_date DATETIME, coach_user_id STRING, session_type STRING, status STRING, summary STRING, action_items_json STRING, next_session_date DATETIME) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_coaching_task (PRIMARY_ID task_id STRING, title STRING, category STRING, instruction STRING, status STRING, priority STRING, created_date DATETIME, due_date DATETIME, completed_date DATETIME, created_by_user_id STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_manager_review (PRIMARY_ID review_id STRING, review_date DATETIME, reviewer_user_id STRING, review_type STRING, rating DOUBLE, summary STRING, status STRING) WITH primary_id_as_attribute="true";
