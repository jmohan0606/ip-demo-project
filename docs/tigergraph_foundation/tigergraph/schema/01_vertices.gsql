CREATE VERTEX phx_dm_crm_lead (PRIMARY_ID lead_id STRING, source STRING, created_date DATETIME, due_date DATETIME, status STRING, completed_date DATETIME, converted_flag BOOL, priority STRING, estimated_value DOUBLE) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_crm_referral (PRIMARY_ID referral_id STRING, source STRING, received_date DATETIME, due_date DATETIME, status STRING, completed_date DATETIME, converted_flag BOOL, priority STRING, estimated_value DOUBLE) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_crm_opportunity (PRIMARY_ID crm_opportunity_id STRING, name STRING, stage STRING, amount DOUBLE, probability DOUBLE, expected_close_date DATETIME, status STRING, next_action STRING, next_action_date DATETIME, source_type STRING) WITH primary_id_as_attribute="true";
