CREATE VERTEX phx_dm_branch (PRIMARY_ID branch_id STRING, branch_name STRING, branch_code STRING, status STRING, city STRING, state STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_advisor (PRIMARY_ID advisor_id STRING, advisor_name STRING, employee_id STRING, status STRING, hire_date DATETIME, tenure_months INT, agp_flag BOOL, segment STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_rep_pool (PRIMARY_ID rep_pool_id STRING, pool_name STRING, pool_type STRING, status STRING) WITH primary_id_as_attribute="true";
