CREATE VERTEX phx_dm_notification (PRIMARY_ID notification_id STRING, notification_type STRING, title STRING, message STRING, severity STRING, status STRING, created_at DATETIME, due_date DATETIME) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_simulation_scenario (PRIMARY_ID scenario_id STRING, scenario_type STRING, scope_type STRING, scope_id STRING, assumptions_json STRING, baseline_json STRING, projected_json STRING, created_at DATETIME) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_agent_execution (PRIMARY_ID execution_id STRING, agent_name STRING, workflow_name STRING, persona STRING, scope_type STRING, scope_id STRING, status STRING, started_at DATETIME, completed_at DATETIME, latency_ms INT, model_name STRING, prompt_version STRING) WITH primary_id_as_attribute="true";
