CREATE VERTEX phx_dm_guardrail_event (PRIMARY_ID guardrail_event_id STRING, event_type STRING, severity STRING, action STRING, matched_rule STRING, redacted_content STRING, created_at DATETIME) WITH primary_id_as_attribute="true";
