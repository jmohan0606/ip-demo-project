USE GLOBAL

CREATE VERTEX phx_dm_persona_user (PRIMARY_ID user_id STRING, display_name STRING, email STRING, role_code STRING, status STRING, default_scope_type STRING, default_scope_id STRING) WITH primary_id_as_attribute="true";
