CREATE VERTEX phx_dm_monthly_nnm (PRIMARY_ID nnm_id STRING, month_end DATETIME, nnm_amount DOUBLE) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_monthly_product_revenue (PRIMARY_ID product_revenue_id STRING, month_end DATETIME, revenue_amount DOUBLE) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_eligibility (PRIMARY_ID eligibility_id STRING, eligibility_type STRING, eligible_flag BOOL, reason STRING, effective_date DATETIME, expiration_date DATETIME) WITH primary_id_as_attribute="true";
