CREATE VERTEX phx_dm_account (PRIMARY_ID account_id STRING, account_name STRING, account_type STRING, status STRING, opened_date DATETIME, current_value DOUBLE) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_product_category (PRIMARY_ID category_id STRING, category_name STRING, status STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_product_subcategory (PRIMARY_ID subcategory_id STRING, subcategory_name STRING, status STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_product (PRIMARY_ID product_id STRING, product_name STRING, product_code STRING, risk_level STRING, managed_flag BOOL, status STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_time_period (PRIMARY_ID period_id STRING, period_type STRING, start_date DATETIME, end_date DATETIME, year INT, quarter INT, month INT, label STRING) WITH primary_id_as_attribute="true";
