CREATE VERTEX phx_dm_prediction_result (PRIMARY_ID prediction_id STRING, prediction_type STRING, target_type STRING, target_id STRING, score DOUBLE, confidence DOUBLE, risk_band STRING, severity STRING, horizon_days INT, explanation STRING, status STRING, generated_at DATETIME) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_opportunity (PRIMARY_ID opportunity_id STRING, opportunity_type STRING, category STRING, target_type STRING, target_id STRING, score DOUBLE, severity STRING, estimated_revenue_impact DOUBLE, impact_summary STRING, status STRING, generated_at DATETIME) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_recommendation (PRIMARY_ID recommendation_id STRING, recommendation_type STRING, title STRING, action_text STRING, priority_score DOUBLE, severity STRING, confidence DOUBLE, estimated_revenue_impact DOUBLE, impact_summary STRING, status STRING, due_date DATETIME, generated_at DATETIME) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_feedback_event (PRIMARY_ID feedback_id STRING, action STRING, reason_code STRING, reason_text STRING, created_at DATETIME, user_id STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_outcome_event (PRIMARY_ID outcome_id STRING, outcome_type STRING, outcome_value DOUBLE, outcome_unit STRING, observed_at DATETIME, notes STRING) WITH primary_id_as_attribute="true";
CREATE VERTEX phx_dm_learning_signal (PRIMARY_ID learning_signal_id STRING, signal_type STRING, reward DOUBLE, score_delta DOUBLE, signal_json STRING, created_at DATETIME) WITH primary_id_as_attribute="true";
