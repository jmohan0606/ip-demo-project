/* Generated fallback GSQL loading job for vertices/phx_dm_tool_call.csv.
 * The React/FastAPI RESTPP loader is the primary ingestion path.
 * This job is provided for direct server-side loading and compile verification.
 */
USE GRAPH iperform_insights_coaching_demo
CREATE LOADING JOB load_phx_dm_tool_call FOR GRAPH iperform_insights_coaching_demo {
  DEFINE FILENAME input_file;
  LOAD input_file TO VERTEX phx_dm_tool_call
    VALUES ($"tool_call_id", $"tool_name", $"operation", $"request_summary", $"response_summary", $"status", $"latency_ms", $"error_code")
    USING HEADER="true", SEPARATOR=",", EOL="\n";
}
