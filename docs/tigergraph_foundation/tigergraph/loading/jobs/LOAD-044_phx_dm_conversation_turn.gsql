/* Generated fallback GSQL loading job for vertices/phx_dm_conversation_turn.csv.
 * The React/FastAPI RESTPP loader is the primary ingestion path.
 * This job is provided for direct server-side loading and compile verification.
 */
USE GRAPH iperform_insights_coaching_demo
CREATE LOADING JOB load_phx_dm_conversation_turn FOR GRAPH iperform_insights_coaching_demo {
  DEFINE FILENAME input_file;
  LOAD input_file TO VERTEX phx_dm_conversation_turn
    VALUES ($"turn_id", $"conversation_id", $"turn_no", $"speaker", $"content", $"created_at", $"intent")
    USING HEADER="true", SEPARATOR=",", EOL="\n";
}
